# -------------------------------------------------------------------------
# SECURITY: Never copy secrets into the container!
# -------------------------------------------------------------------------
.env
.env.*
*.pem
secrets/

# -------------------------------------------------------------------------
# VIRTUAL ENVIRONMENTS: Docker handles its own Python environment.
# Copying these makes the build incredibly slow and bloated.
# -------------------------------------------------------------------------
venv/
.venv/
env/
.env/
pip-wheel-metadata/

# -------------------------------------------------------------------------
# PYTHON CACHE: Bytecode compiled for your OS, not the container's OS.
# -------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# -------------------------------------------------------------------------
# GIT & IDE CONFIGS: The container doesn't need your Git history or editor settings.
# -------------------------------------------------------------------------
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo

# -------------------------------------------------------------------------
# OS GENERATED FILES
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------------------------
# UV PACKAGE MANAGER CACHE
# -------------------------------------------------------------------------
.uv/